<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome Back"
            android:textColor="@color/textSecondary"
            android:textSize="18sp"
            android:textStyle="bold" />


        <TextView
            android:id="@+id/btnProfile"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|end"
            android:background="@drawable/circle_profile_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="👤"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Gym Planner"
            android:textColor="@color/textPrimary"
            android:textSize="32sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


        </FrameLayout>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="28dp"
            android:text="Choose what you want to do today"
            android:textColor="@color/textSecondary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnWorkoutPlanner"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="@color/primary"
            android:text="Workout Planner"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnExerciseLibrary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="@color/primary"
            android:text="Exercise Library"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnLogWorkout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="@color/primary"
            android:text="Log Workout"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnProgress"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="@color/primary"
            android:text="Progress"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnReminder"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="@color/primary"
            android:text="Reminders"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnJournal"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="@color/primary"
            android:text="Gym Journal"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnPersonalBests"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="@color/primary"
            android:text="Personal Bests"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary"
            android:textSize="16sp"  />

        <Button
            android:id="@+id/btnBmiCalculator"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="@color/primary"
            android:text="BMI Calculator"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary"
            android:textSize="16sp"  />

        <Button
            android:id="@+id/btnRestTimer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="@color/primary"
            android:text="Rest Timer"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary"
            android:textSize="16sp"  />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/card"
            android:text="Logout"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>