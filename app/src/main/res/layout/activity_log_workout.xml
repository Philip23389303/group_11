<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Log Workout"
            android:textColor="@color/textPrimary"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSelectedDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Selected Date:"
            android:textColor="@color/textSecondary"
            android:textSize="15sp" />

        <CalendarView
            android:id="@+id/calendarViewWorkout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_background"
            android:dateTextAppearance="@style/CalendarDate"
            android:focusedMonthDateColor="@color/textPrimary"
            android:unfocusedMonthDateColor="@color/textSecondary"
            android:weekDayTextAppearance="@style/CalendarWeekDay" />

        <EditText
            android:id="@+id/etExerciseName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/edittext_background"
            android:hint="Workout Split"
            android:inputType="textCapWords"
            android:padding="16dp"
            android:textColor="@color/inputText"
            android:textColorHint="@color/hintText" />

        <EditText
            android:id="@+id/etNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/edittext_background"
            android:gravity="top|start"
            android:hint="Notes (optional)"
            android:inputType="textMultiLine"
            android:padding="16dp"
            android:textColor="@color/inputText"
            android:textColorHint="@color/hintText" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Sets"
            android:textColor="@color/textPrimary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/setsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/logsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:orientation="vertical"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnAddSet"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/button_primary"
            android:text="Add Set"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary" />

        <Button
            android:id="@+id/btnRemoveSet"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/button_secondary"
            android:text="Remove Last Set"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary" />

        <Button
            android:id="@+id/btnSaveWorkout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/button_primary"
            android:text="Save Workout"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary" />

        <Button
            android:id="@+id/btnDeleteSelected"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/button_secondary"
            android:text="Delete Saved Workout"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary" />

        <Button
            android:id="@+id/btnReturnHome"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/button_secondary"
            android:text="Return Home"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>