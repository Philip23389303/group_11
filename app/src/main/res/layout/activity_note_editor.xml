<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvEditorTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New Note"
            android:textColor="@color/textPrimary"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEditorSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:text="Write down goals, reflections or workout thoughts"
            android:textColor="@color/textSecondary"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etNoteTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edittext_background"
            android:hint="Note title"
            android:inputType="textCapWords"
            android:padding="16dp"
            android:textColor="@color/inputText"
            android:textColorHint="@color/hintText"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/etNoteContent"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/edittext_background"
            android:gravity="top|start"
            android:hint="Write your note here..."
            android:inputType="textMultiLine"
            android:padding="16dp"
            android:textColor="@color/inputText"
            android:textColorHint="@color/hintText"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnSaveNote"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/button_primary"
            android:text="Save Note"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary" />

        <Button
            android:id="@+id/btnDeleteNote"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/button_secondary"
            android:text="Delete Note"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary" />

        <Button
            android:id="@+id/btnBackJournal"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/button_secondary"
            android:text="Back to Journal"
            android:textAllCaps="false"
            android:textColor="@color/textPrimary" />

    </LinearLayout>
</ScrollView>